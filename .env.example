# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated allowed frontend origins for CORS (production)
# Example: https://your-app.onrender.com,https://your-app.vercel.app
CORS_ORIGINS=

# Optional single frontend URL (also accepted for CORS)
FRONTEND_URL=

# Captcha solving (optional — OCR fallback works without this)
TWO_CAPTCHA_API_KEY=
CAPTCHA_API_KEY=
